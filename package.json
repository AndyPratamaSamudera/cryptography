{
  "name": "crypto-rsa-hash-app",
  "version": "1.0.0",
  "private": true,
  "description": "Simple RSA and hash utilities with Express + TypeScript",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/app.ts",
    "build": "tsc && copyfiles -u 1 \"views/**/*\" dist/views && copyfiles -u 1 \"public/**/*\" dist/public",
    "start": "node dist/app.js"
  },
  "dependencies": {
    "ejs": "^3.1.10",
    "express": "^4.22.1"
  },
  "devDependencies": {
    "@types/ejs": "^3.1.5",
    "@types/express": "^4.17.25",
    "@types/node": "^22.19.17",
    "copyfiles": "^2.4.1",
    "nodemon": "^3.1.14",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.3"
  }
}
