<%- include('partials/head', { title, activePage }) %>
<%- include('partials/nav') %>

<main class="mx-auto min-w-0 max-w-2xl px-4 py-6">
  <h1 class="text-lg font-medium text-gray-900">Hash</h1>
  <div class="mt-6 space-y-5">
    <div>
      <label class="text-sm text-gray-600" for="hashInput">Teks</label>
      <textarea id="hashInput" rows="4" class="mt-1 w-full border border-gray-300 px-2 py-2 text-sm focus:border-gray-400 focus:outline-none"></textarea>
    </div>

    <div class="flex flex-wrap items-end gap-3">
      <div>
        <label class="text-sm text-gray-600" for="algorithm">Algoritma</label>
        <select id="algorithm" class="mt-1 block border border-gray-300 bg-white px-2 py-2 text-sm focus:border-gray-400 focus:outline-none">
          <option value="sha256">SHA-256</option>
          <option value="sha512">SHA-512</option>
          <option value="md5">MD5</option>
        </select>
      </div>
      <button type="button" id="btnHash" class="border border-gray-300 bg-gray-100 px-3 py-1.5 text-sm text-gray-800 hover:bg-gray-200">Generate</button>
    </div>

    <div id="hashMessage" class="hidden border px-3 py-2 text-sm" role="status"></div>

    <div class="min-w-0">
      <p class="text-sm text-gray-600">Hash</p>
      <pre id="hashOutput" class="mt-1 w-full max-w-full min-w-0 whitespace-pre-wrap break-all border border-gray-200 bg-gray-50 px-2 py-2 font-mono text-xs text-gray-800 min-h-[2.5rem] box-border"></pre>
    </div>
  </div>
</main>

<script>
(function () {
  const hashInput = document.getElementById('hashInput');
  const algorithm = document.getElementById('algorithm');
  const hashOutput = document.getElementById('hashOutput');
  const hashMessage = document.getElementById('hashMessage');

  function showMessage(text, isError) {
    hashMessage.textContent = text;
    hashMessage.classList.remove('hidden');
    hashMessage.className =
      'border px-3 py-2 text-sm ' +
      (isError ? 'border-gray-600 bg-gray-200 text-gray-900' : 'border-gray-300 bg-gray-100 text-gray-800');
  }

  function clearMessage() {
    hashMessage.classList.add('hidden');
    hashMessage.textContent = '';
  }

  document.getElementById('btnHash').addEventListener('click', async function () {
    clearMessage();
    hashOutput.textContent = '';
    try {
      const res = await fetch('/api/hash', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          plainText: hashInput.value,
          algorithm: algorithm.value,
        }),
      });
      const data = await res.json().catch(function () { return {}; });
      if (!res.ok || !data.success) {
        throw new Error(data.error || 'Gagal');
      }
      hashOutput.textContent = data.data.hashHex;
    } catch (e) {
      showMessage(e.message, true);
    }
  });
})();
</script>

</body>
</html>
