<%- include('partials/head', { title, activePage }) %>
  <%- include('partials/nav') %>

    <main class="main-content px-4 py-8 md:px-8 lg:px-12">
      <div class="max-w-4xl mx-auto space-y-6">

        <!-- Page header -->
        <div class="mb-2">
          <h2 class="text-2xl font-bold text-gray-100">Hash Generator</h2>
          <p class="mt-1 text-sm text-gray-400">Buat hash digest dari teks menggunakan SHA-256, SHA-512, atau MD5.</p>
        </div>

        <!-- ====================== Card: Hash ====================== -->
        <section class="glass-card p-6 fade-in">
          <div class="flex items-center gap-3 mb-5">
            <h3 class="text-lg font-semibold text-gray-100">Generate Hash</h3>
          </div>

          <div class="space-y-4">
            <div>
              <label class="field-label" for="hashInput">Input Teks</label>
              <textarea id="hashInput" rows="4" class="input-field"
                placeholder="Masukkan teks yang ingin di-hash..."></textarea>
            </div>

            <div class="flex flex-wrap items-end gap-3">
              <div>
                <label class="field-label" for="algorithm">Algoritma</label>
                <select id="algorithm" class="select-field">
                  <option value="sha256">SHA-256</option>
                  <option value="sha512">SHA-512</option>
                  <option value="md5">MD5</option>
                </select>
              </div>
              <button type="button" id="btnHash" class="btn btn-primary">Generate Hash</button>
            </div>

            <div>
              <div class="flex items-center justify-between mb-1.5">
                <label class="field-label mb-0">Hasil Hash</label>
                <button type="button" id="btnCopyHash" class="btn-icon" title="Copy Hash">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                    stroke-linecap="round" stroke-linejoin="round">
                    <rect x="9" y="9" width="13" height="13" rx="2" />
                    <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1" />
                  </svg>
                </button>
              </div>
              <div id="hashOutput" class="output-area"></div>
            </div>
          </div>
        </section>

      </div>
    </main>

    <script src="/js/api.js"></script>
    <script src="/js/hash.js"></script>
    </body>

    </html>