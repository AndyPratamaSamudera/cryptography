<%- include('partials/head', { title, activePage }) %>
  <%- include('partials/nav') %>

    <main class="main-content px-4 py-8 md:px-8 lg:px-12">
      <div class="max-w-4xl mx-auto space-y-6">

        <!-- Page header -->
        <div class="mb-2">
          <h2 class="text-2xl font-bold text-gray-100">RSA Encryption</h2>
          <p class="mt-1 text-sm text-gray-400">Enkripsi & dekripsi teks menggunakan RSA 2048-bit. Kunci PEM, cipher
            Base64.</p>
        </div>

        <!-- ====================== Card 1: Generate Key Pair ====================== -->
        <section class="glass-card p-6 fade-in">
          <div class="flex items-center justify-between mb-5">
            <div class="flex items-center gap-3">
              <h3 class="text-lg font-semibold text-gray-100">Generate Key Pair</h3>
            </div>
            <button type="button" id="btnGenerateKeys" class="btn btn-primary">Generate</button>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <!-- Public Key -->
            <div>
              <div class="flex items-center justify-between mb-1.5">
                <label class="field-label mb-0" for="publicKeyOut">Public Key</label>
                <button type="button" id="btnCopyPublic" class="btn-icon" title="Copy Public Key">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                    stroke-linecap="round" stroke-linejoin="round">
                    <rect x="9" y="9" width="13" height="13" rx="2" />
                    <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1" />
                  </svg>
                </button>
              </div>
              <textarea id="publicKeyOut" rows="7" readonly class="input-field mono"
                placeholder="Klik Generate untuk membuat kunci..."></textarea>
            </div>
            <!-- Private Key -->
            <div>
              <div class="flex items-center justify-between mb-1.5">
                <label class="field-label mb-0" for="privateKeyOut">Private Key</label>
                <button type="button" id="btnCopyPrivate" class="btn-icon" title="Copy Private Key">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                    stroke-linecap="round" stroke-linejoin="round">
                    <rect x="9" y="9" width="13" height="13" rx="2" />
                    <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1" />
                  </svg>
                </button>
              </div>
              <textarea id="privateKeyOut" rows="7" readonly class="input-field mono"
                placeholder="Klik Generate untuk membuat kunci..."></textarea>
            </div>
          </div>
        </section>

        <!-- ====================== Card 2: Encrypt ====================== -->
        <section class="glass-card p-6 fade-in">
          <div class="flex items-center gap-3 mb-5">
            <h3 class="text-lg font-semibold text-gray-100">Encrypt</h3>
          </div>

          <div class="space-y-4">
            <div>
              <label class="field-label" for="encPlainText">Plain Text</label>
              <textarea id="encPlainText" rows="3" class="input-field"
                placeholder="Masukkan teks yang ingin dienkripsi..."></textarea>
            </div>
            <div>
              <label class="field-label" for="encPublicKey">Public Key (PEM)</label>
              <textarea id="encPublicKey" rows="5" class="input-field mono"
                placeholder="Paste public key di sini, atau generate dulu di atas..."></textarea>
            </div>
            <div class="flex items-center gap-3">
              <button type="button" id="btnEncrypt" class="btn btn-primary">Encrypt</button>
            </div>
            <div>
              <div class="flex items-center justify-between mb-1.5">
                <label class="field-label mb-0">Cipher Text (Base64)</label>
                <button type="button" id="btnCopyCipher" class="btn-icon" title="Copy Cipher Text">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                    stroke-linecap="round" stroke-linejoin="round">
                    <rect x="9" y="9" width="13" height="13" rx="2" />
                    <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1" />
                  </svg>
                </button>
              </div>
              <div id="encOutput" class="output-area"></div>
            </div>
          </div>
        </section>

        <!-- ====================== Card 3: Decrypt ====================== -->
        <section class="glass-card p-6 fade-in">
          <div class="flex items-center gap-3 mb-5">
            <h3 class="text-lg font-semibold text-gray-100">Decrypt</h3>
          </div>

          <div class="space-y-4">
            <div>
              <label class="field-label" for="decCipherText">Cipher Text (Base64)</label>
              <textarea id="decCipherText" rows="3" class="input-field mono"
                placeholder="Paste cipher text dari hasil enkripsi..."></textarea>
            </div>
            <div>
              <label class="field-label" for="decPrivateKey">Private Key (PEM)</label>
              <textarea id="decPrivateKey" rows="5" class="input-field mono"
                placeholder="Paste private key di sini, atau generate dulu di atas..."></textarea>
            </div>
            <div class="flex items-center gap-3">
              <button type="button" id="btnDecrypt" class="btn btn-primary">Decrypt</button>
            </div>
            <div>
              <div class="flex items-center justify-between mb-1.5">
                <label class="field-label mb-0">Hasil Dekripsi</label>
                <button type="button" id="btnCopyPlain" class="btn-icon" title="Copy Plain Text">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                    stroke-linecap="round" stroke-linejoin="round">
                    <rect x="9" y="9" width="13" height="13" rx="2" />
                    <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1" />
                  </svg>
                </button>
              </div>
              <div id="decOutput" class="output-area"></div>
            </div>
          </div>
        </section>

      </div>
    </main>

    <script src="/js/api.js"></script>
    <script src="/js/rsa.js"></script>
    </body>

    </html>