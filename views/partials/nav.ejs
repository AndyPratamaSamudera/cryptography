<!-- Hamburger (mobile) -->
<button id="hamburger" class="hamburger" aria-label="Toggle menu">
  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
    stroke-linecap="round" stroke-linejoin="round">
    <line x1="3" y1="6" x2="21" y2="6" />
    <line x1="3" y1="12" x2="21" y2="12" />
    <line x1="3" y1="18" x2="21" y2="18" />
  </svg>
</button>

<!-- Overlay (mobile) -->
<div id="sidebar-overlay" class="sidebar-overlay"></div>

<!-- Sidebar -->
<aside id="sidebar" class="sidebar fixed top-0 left-0 h-screen flex flex-col">
  <!-- Branding -->
  <div class="px-6 py-6">
    <div class="flex items-center gap-3">
      <div class="w-9 h-9 rounded-xl flex items-center justify-center"
        style="background: linear-gradient(135deg, var(--accent-from), var(--accent-to));">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2"
          stroke-linecap="round" stroke-linejoin="round">
          <rect x="3" y="11" width="18" height="11" rx="2" ry="2" />
          <path d="M7 11V7a5 5 0 0110 0v4" />
        </svg>
      </div>
      <div>
        <h1 class="text-sm font-semibold text-gray-100">Crypto Tools</h1>
        <p class="text-[0.6875rem] text-gray-500">RSA & Hash</p>
      </div>
    </div>
  </div>

  <!-- Navigation -->
  <nav class="flex-1 px-4 space-y-1">
    <p class="px-3 mb-2 text-[0.6875rem] font-semibold text-gray-500 uppercase tracking-wider">Menu</p>
    <a href="/rsa" class="nav-item <%= activePage === 'rsa' ? 'active' : '' %>">
      <svg class="nav-icon w-5 h-5 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"
        stroke-linecap="round" stroke-linejoin="round">
        <rect x="3" y="11" width="18" height="11" rx="2" ry="2" />
        <path d="M7 11V7a5 5 0 0110 0v4" />
      </svg>
      RSA Encryption
    </a>
    <a href="/hash" class="nav-item <%= activePage === 'hash' ? 'active' : '' %>">
      <svg class="nav-icon w-5 h-5 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"
        stroke-linecap="round" stroke-linejoin="round">
        <line x1="4" y1="9" x2="20" y2="9" />
        <line x1="4" y1="15" x2="20" y2="15" />
        <line x1="10" y1="3" x2="8" y2="21" />
        <line x1="16" y1="3" x2="14" y2="21" />
      </svg>
      Hash Generator
    </a>
  </nav>
</aside>